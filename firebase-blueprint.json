{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "GardenLayout": {
      "title": "Garden Layout",
      "description": "A saved garden layout design",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "width": { "type": "number" },
        "height": { "type": "number" },
        "items": { "type": "array", "items": { "type": "object" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "items"]
    },
    "NewsletterSubscriber": {
      "title": "Newsletter Subscriber",
      "description": "User subscribed to the newsletter",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "subscribedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/layouts/{layoutId}": {
      "schema": "GardenLayout",
      "description": "Saved garden layouts"
    },
    "/newsletter_subscribers/{email}": {
      "schema": "NewsletterSubscriber",
      "description": "Newsletter subscriptions"
    }
  }
}
